{
  "expo": {
    "name": "20260515",
    "slug": "20260515",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/carrot.png",
    "scheme": "carrot",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/carrot.png",
      "bundleIdentifier": "com.carrot0526.market",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/carrot.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.carrot0526.market"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/carrot.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "53dbcbfe-10ab-4f3d-ad15-92a5c39c842e"
      }
    }
  }
}
